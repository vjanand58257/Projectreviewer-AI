# =====================================================================
# ProjectReviewer AI - Backend Environment Variable Template
# Copy this file to '.env' and fill in the values. Do not commit '.env'.
# =====================================================================

# Flask secret session key for encrypting client cookies/sessions (Required)
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Gemini API Authentication Key from Google AI Studio (Required for AI Agents)
GEMINI_API_KEY=AIzaSy...your-actual-gemini-key-goes-here

# SQLite Database connection URL (Defaults to local instance folder)
DATABASE_URL=sqlite:///instance/project_reviewer.db